# Oddvice API configuration
APP_ENV=development
HOST=0.0.0.0
PORT=8080
# Comma-separated CORS allow-list. Use "*" to allow any origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Football data provider (TheSportsDB free API; "3" is the public test key).
FOOTBALL_API_BASE_URL=https://www.thesportsdb.com
FOOTBALL_API_KEY=3
FOOTBALL_API_TIMEOUT_SECONDS=10

# News provider (Google News RSS; free, no key). Default feed: World Cup 2026.
NEWS_FEED_URL=https://news.google.com/rss/search?q=Cupa%20Mondiala%202026&hl=ro&gl=RO&ceid=RO:ro
NEWS_LIMIT=30
NEWS_TIMEOUT_SECONDS=10
