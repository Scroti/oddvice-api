# Oddvice API configuration
APP_ENV=development
HOST=0.0.0.0
PORT=8080
# Comma-separated CORS allow-list. Use "*" to allow any origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Football data provider (football-data.org). Get a free key at
# https://www.football-data.org/client/register and put it in .env (gitignored).
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org
FOOTBALL_COMPETITION=WC
FOOTBALL_TIMEOUT_SECONDS=12
FOOTBALL_CACHE_SECONDS=120

# News provider (Google News RSS; free, no key). Default feed: World Cup 2026.
NEWS_FEED_URL=https://news.google.com/rss/search?q=Cupa%20Mondiala%202026&hl=ro&gl=RO&ceid=RO:ro
NEWS_LIMIT=30
NEWS_TIMEOUT_SECONDS=10
