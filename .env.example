# Oddvice API configuration. Copy to .env and fill in. NEVER commit .env (gitignored).
APP_ENV=development

# Bind address. Behind a reverse proxy (Caddy) in production, set HOST=127.0.0.1.
HOST=0.0.0.0
PORT=8080

# Comma-separated EXACT web origins allowed to call the API (CORS): scheme+host(+port).
# Use "*" to allow any origin. In production add your deployed web origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# football-data.org — matches, standings. Free key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org
FOOTBALL_COMPETITION=WC
FOOTBALL_TIMEOUT_SECONDS=12
FOOTBALL_CACHE_SECONDS=120

# api-football.com — team stats, formations, lineups. Key: https://www.api-football.com/
# Season 2026 needs a paid plan (free covers 2022-2024).
APIFOOTBALL_API_KEY=
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io
APIFOOTBALL_LEAGUE=1
APIFOOTBALL_SEASON=2026
APIFOOTBALL_TIMEOUT_SECONDS=12
APIFOOTBALL_CACHE_SECONDS=21600

# News (Google News RSS; free, no key). The feed is localized per request by the
# app's language, so no feed URL is configured here.
NEWS_LIMIT=30
NEWS_TIMEOUT_SECONDS=10
